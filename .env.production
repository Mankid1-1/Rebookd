# ════════════════════════════════════════════════════════════════════════════════
# REBOOKD v2 - PRODUCTION ENVIRONMENT CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.production and fill in your actual values
# NEVER commit secrets to git!

# ─── APPLICATION ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://app.rebooked.org
LOG_LEVEL=info

# ─── TIMEZONE ─────────────────────────────────────────────────────────────────────
# Used for all database operations and cron jobs
TIMEZONE=America/New_York

# ─── DATABASE ─────────────────────────────────────────────────────────────────────
# For docker-compose: use 'db' as hostname (service name in docker-compose.yml)
# For standalone: use 'localhost' or your MySQL server IP
DB_HOST=db
DB_PORT=3306
DB_USER=rebookd
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
DB_NAME=rebookd
DB_ROOT_PASSWORD=CHANGE_ME_TO_SECURE_ROOT_PASSWORD
DB_POOL_SIZE=20

# Alternative: Use DATABASE_URL directly (takes precedence)
# DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── REDIS (Optional but recommended) ──────────────────────────────────────────
# Used for: Rate limiting, caching, job queue
REDIS_URL=redis://redis:6379

# ─── SECURITY ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# JWT Secret (sign session tokens)
JWT_SECRET=CHANGE_ME_32_BYTE_HEX_STRING_MINIMUM

# Encryption Key (encrypt PII: phone, name, email)
# MUST be 64 hex characters (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_FOR_32_BYTES

# Webhook Secret (verify incoming webhooks)
WEBHOOK_SECRET=CHANGE_ME_MINIMUM_32_CHARS_RANDOM

# Cookie Secret (for session encryption)
COOKIE_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING

# ─── SMS PROVIDERS ────────────────────────────────────────────────────────────────
# Choose ONE: Telnyx (preferred, pay-per-message) or Twilio (fallback)

# TELNYX (Recommended - $0.004/SMS, no monthly fee)
# Sign up: https://telnyx.com
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=+1234567890
TELNYX_PUBLIC_KEY=

# TWILIO (Fallback)
# Sign up: https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# ─── EMAIL ────────────────────────────────────────────────────────────────────────
# Option 1: SendGrid (easiest)
SENDGRID_API_KEY=

# Option 2: Direct SMTP (e.g., your hosting provider's mail server)
# Examples:
#   mail.rebooked.org (if using cPanel mail)
#   smtp.gmail.com (Gmail)
#   smtp.mailgun.org (Mailgun)
SMTP_HOST=mail.rebooked.org
SMTP_PORT=587
SMTP_USER=hello@rebooked.org
SMTP_PASSWORD=
SMTP_FROM=hello@rebooked.org

# ─── AI / LLM ─────────────────────────────────────────────────────────────────────
# OpenAI API for tone-based message rewriting
# Sign up: https://platform.openai.com
OPENAI_API_KEY=sk-...

# ─── BILLING / PAYMENTS ───────────────────────────────────────────────────────────
# Stripe for subscription billing
# Sign up: https://stripe.com
# Get keys: https://dashboard.stripe.com/apikeys

# Stripe Secret Key (KEEP PRIVATE)
STRIPE_SECRET_KEY=sk_live_...

# Stripe Webhook Secret (for webhook event verification)
# Create webhook endpoint at: https://dashboard.stripe.com/webhooks
# Point to: https://app.rebooked.org/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── MONITORING & ERROR TRACKING ──────────────────────────────────────────────────
# Sentry for error tracking and monitoring
# Sign up: https://sentry.io
SENTRY_DSN=https://...@sentry.io/...

# ─── ALLOWED ORIGINS (CORS) ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests
ALLOWED_ORIGINS=https://app.rebooked.org,https://rebooked.org

# ─── SESSION ──────────────────────────────────────────────────────────────────────
SESSION_EXPIRY_DAYS=30
SESSION_COOKIE_DOMAIN=.rebooked.org
SESSION_COOKIE_NAME=app_session_id

# ─── RATE LIMITING ────────────────────────────────────────────────────────────────
# SMS rate limit per tenant per minute
SMS_RATE_LIMIT_PER_MINUTE=60

# Auth rate limit (login/signup attempts)
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# API global rate limit
API_RATE_LIMIT_REQUESTS=600
API_RATE_LIMIT_WINDOW_MINUTES=5

# ─── WORKER CONFIGURATION ────────────────────────────────────────────────────────
# Run automation engine in separate process
WORKER_MODE=true
# Interval (ms) between automation cycles (default: 60 seconds)
WORKER_INTERVAL=60000
# Max concurrent automations per cycle
WORKER_MAX_CONCURRENT=10

# ─── BACKUP & MAINTENANCE ────────────────────────────────────────────────────────
# Backup frequency (daily, weekly)
BACKUP_FREQUENCY=daily
BACKUP_TIME=02:00  # 2 AM UTC

# Database log retention (days)
LOG_RETENTION_DAYS=30

# Archive old messages (days before archival)
MESSAGE_ARCHIVE_AFTER_DAYS=365

# ─── FEATURE FLAGS ────────────────────────────────────────────────────────────────
# Enable/disable features
FEATURE_AI_REWRITE=true
FEATURE_CUSTOM_WEBHOOKS=true
FEATURE_MULTI_WORKSPACE=false
FEATURE_ADVANCED_ANALYTICS=true

# ─── DEVELOPMENT MODE OVERRIDES ───────────────────────────────────────────────────
# Dev mode: allow unsigned webhooks
WEBHOOK_ALLOW_UNSIGNED=false

# Dev mode: log all requests
REQUEST_LOGGING=false

# Dev mode: simulate SMS (don't send to provider)
SIMULATE_SMS=false

# ─── DOCKER-SPECIFIC ──────────────────────────────────────────────────────────────
# Used by docker-compose.yml
COMPOSE_PROJECT_NAME=rebookd
DOCKER_ENV=true
