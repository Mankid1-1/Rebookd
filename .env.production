# ════════════════════════════════════════════════════════════════════════════════
# REBOOKD v2 - PRODUCTION ENVIRONMENT CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# ─── APPLICATION ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=info

# ─── TIMEZONE ─────────────────────────────────────────────────────────────────────
TIMEZONE=America/New_York

# ─── DATABASE ─────────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_USER=rebookd
DB_PASSWORD=RebookdProd2024SecurePass123!
DB_NAME=rebookd
DB_ROOT_PASSWORD=RebookdRootSecure2024!Root
DB_POOL_SIZE=20

# ─── REDIS ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── SECURITY ─────────────────────────────────────────────────────────────────────
JWT_SECRET=53e12cde2ae453bbd4d2bc131f9a3a2751522f38dd66f9d8623490ff7b489f2f

ENCRYPTION_KEY=7a8f9e3d2c1b4a5f6e7d8c9b0a1f2e3d4c5b6a7f8e9d0c1b2a3f4e5d6c7b8a

WEBHOOK_SECRET=webhook_secret_rebookd_2024_secure_32chars_minimum

COOKIE_SECRET=cookie_secret_rebookd_2024_secure

# ─── SMS PROVIDERS ────────────────────────────────────────────────────────────────
# Using Telnyx (pay-per-message model)
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=
TELNYX_PUBLIC_KEY=

# Fallback: Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── EMAIL - CPANEL MAIL SERVER ───────────────────────────────────────────────────
# Your cPanel mail server configuration
SMTP_HOST=mail.rebooked.org
SMTP_PORT=587
SMTP_USER=hello@rebooked.org
SMTP_PASSWORD=
SMTP_FROM=hello@rebooked.org
SMTP_SECURE=true

# ─── AI / LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── BILLING / PAYMENTS ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── MONITORING ──────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── CORS ─────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost,http://173.249.56.141

# ─── SESSION ──────────────────────────────────────────────────────────────────────
SESSION_EXPIRY_DAYS=30
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_NAME=app_session_id

# ─── RATE LIMITING ────────────────────────────────────────────────────────────────
SMS_RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
API_RATE_LIMIT_REQUESTS=600
API_RATE_LIMIT_WINDOW_MINUTES=5

# ─── WORKER CONFIGURATION ────────────────────────────────────────────────────────
WORKER_MODE=true
WORKER_INTERVAL=60000
WORKER_MAX_CONCURRENT=10

# ─── BACKUP & MAINTENANCE ────────────────────────────────────────────────────────
BACKUP_FREQUENCY=daily
BACKUP_TIME=02:00
LOG_RETENTION_DAYS=30
MESSAGE_ARCHIVE_AFTER_DAYS=365

# ─── FEATURE FLAGS ────────────────────────────────────────────────────────────────
FEATURE_AI_REWRITE=true
FEATURE_CUSTOM_WEBHOOKS=true
FEATURE_MULTI_WORKSPACE=false
FEATURE_ADVANCED_ANALYTICS=true

# ─── DEVELOPMENT MODE ────────────────────────────────────────────────────────────
WEBHOOK_ALLOW_UNSIGNED=false
REQUEST_LOGGING=true
SIMULATE_SMS=false

# ─── DOCKER ───────────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=rebookd
DOCKER_ENV=true
