# VPS Production Environment Template
# Copy this to .env.vps and fill in your actual values

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
DOCKER_ENV=true
APP_URL=https://rebooked.org
CORS_ORIGIN=https://rebooked.org
COOKIE_DOMAIN=.rebooked.org

# ─── Database ─────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=your_mysql_root_password_here
DB_PASSWORD=your_mysql_user_password_here

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_32_character_random_secret_here
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here
WEBHOOK_SECRET=your_32_character_hex_webhook_secret_here

# ─── Email (mail.rebooked.org) ────────────────────────────────────────────────
SMTP_HOST=mail.rebooked.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@rebooked.org
SMTP_PASS=your_smtp_email_password_here
EMAIL_FROM_ADDRESS=noreply@rebooked.org

POP3_HOST=mail.rebooked.org
POP3_PORT=995
POP3_TLS=true
POP3_USER=noreply@rebooked.org
POP3_PASSWORD=your_pop3_email_password_here

# ─── SMS Providers ───────────────────────────────────────────────────────────
# Telnyx (recommended)
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_FROM_NUMBER=+1your_telnyx_phone_number_here
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Twilio (fallback)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1your_twilio_phone_number_here

# ─── Payment Processing ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ─── AI Services ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here

# ─── Email Service (SendGrid fallback) ──────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn_here

# ─── Timeouts and Limits ───────────────────────────────────────────────────────
SMS_HTTP_TIMEOUT_MS=30000
DATA_API_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=5000
SMS_RATE_LIMIT=100
SMS_HOURLY_CAP=1000
SMS_DAILY_CAP_PER_TENANT=5000

# ─── Phone Settings ─────────────────────────────────────────────────────────────
PHONE_DEFAULT_REGION=US
INBOUND_AUTO_CREATE_LEADS=true
MIN_INBOUND_LEAD_BODY_LEN=1
TCPA_STOP_REPLY_TEXT=You have been unsubscribed from SMS. Reply START to opt back in.

# ─── Optional Settings ─────────────────────────────────────────────────────────
# Cloudflare Turnstile (anti-spam)
# TURNSTILE_SITE_KEY=your_turnstile_site_key_here
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Database pool size
# DB_POOL_SIZE=10

# Worker heartbeat file
# WORKER_HEARTBEAT_FILE=/tmp/worker-heartbeat.json
