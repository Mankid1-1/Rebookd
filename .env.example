# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# Free MySQL options: Railway (railway.app), PlanetScale (planetscale.com), Aiven (aiven.io)
# Railway sets DATABASE_URL automatically; the app also checks RAILWAY_URL as fallback.
DATABASE_URL=mysql://root:password@localhost:3306/rebooked

# ─── Auth ─────────────────────────────────────────────────────────────────────
# 32+ character random string — signs session cookies
# Generate one: https://generate-secret.vercel.app/32
JWT_SECRET=replace-with-a-long-random-secret

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_ID=rebooked
OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:3000
OWNER_OPEN_ID=placeholder
APP_URL=http://localhost:3000

# Browser API origins (comma-separated). Required if SPA and API use different hostnames.
# CORS_ORIGIN=https://app.example.com,https://example.com
# Session cookie domain for subdomains (leading dot = all subdomains, e.g. .example.com)
# COOKIE_DOMAIN=
# Default ISO 3166-1 region for phone parsing without country code (libphonenumber-js)
# PHONE_DEFAULT_REGION=US
# SMS caps — counts outbound non-failed rows in `messages` (0 = disabled)
# SMS_HOURLY_CAP=0
# SMS_DAILY_CAP_PER_TENANT=0
# Inbound SMS: create lead on first message (false = only existing leads get messages)
# INBOUND_AUTO_CREATE_LEADS=true
# MIN_INBOUND_LEAD_BODY_LEN=1
# TCPA_STOP_REPLY_TEXT=You have been unsubscribed from SMS. Reply START to opt back in.

# Cloudflare Turnstile (recommended for signup spam prevention)
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ─── Inbound integrations (tRPC webhooks.receive) ─────────────────────────────
# Required in production. HMAC-SHA256 hex of JSON.stringify({ event, data, tenantId }) using this secret.
# Development: set WEBHOOK_ALLOW_UNSIGNED=true only on trusted local machines.
WEBHOOK_SECRET=
# WEBHOOK_ALLOW_UNSIGNED=true

# ─── Timeouts (optional) ─────────────────────────────────────────────────────
# SMS_HTTP_TIMEOUT_MS=30000
# DATA_API_TIMEOUT_MS=30000
# DB_QUERY_TIMEOUT_MS=5000

# ─── SMS — Telnyx (recommended, pay-per-message, no subscription) ─────────────
# Sign up at telnyx.com → get $10 free credit → Mission Control → API Keys
# Inbound webhook: https://yourdomain.com/api/sms/inbound
TELNYX_API_KEY=KEY0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELNYX_FROM_NUMBER=+15550000000

# ─── SMS — Twilio (fallback, only used if Telnyx is not configured) ───────────
# Sign up at twilio.com → Console → Account Info
# Inbound webhook: https://yourdomain.com/api/twilio/inbound
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15550000001

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PROFESSIONAL=price_1...
STRIPE_PRICE_ENTERPRISE=price_1...

# ─── Email (SendGrid, optional but recommended in production) ─────────────────
SENDGRID_API_KEY=SG.xxxxx
EMAIL_FROM_ADDRESS=hello@rebooked.com

# SMTP (local mail.rebooked.org server) - overrides SendGrid if configured
SMTP_HOST=mail.rebooked.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@rebooked.org
SMTP_PASS=your_smtp_password

# POP3 (incoming email processing from mail.rebooked.org)
POP3_HOST=mail.rebooked.org
POP3_PORT=995
POP3_TLS=true
POP3_USER=noreply@rebooked.org
POP3_PASSWORD=your_pop3_password

# ─── AI (OpenAI, for message rewriting) ──────────────────────────────────────
OPENAI_API_KEY=sk-xxx

# ─── PII Encryption ───────────────────────────────────────────────────────────
# 64 hex chars (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production to encrypt phone numbers and names at rest.
ENCRYPTION_KEY=

# ─── Observability (Sentry) ───────────────────────────────────────────────────
# Optional. Get your DSN at sentry.io (free tier available).
# Install SDK first: pnpm add @sentry/node
SENTRY_DSN=

# ─── Stripe Connect (Multi-tenant Payment Platform) ───────────────────────────
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PLATFORM_PRICE_ID=price_xxx

# ─── Sentry DSN (Provided) ───────────────────────────────────────────────────
# https://453e71c19f8e1bc6d6de07f366260a32@o4511089469947904.ingest.us.sentry.io/4511089470930944
SENTRY_DSN=https://453e71c19f8e1bc6d6de07f366260a32@o4511089469947904.ingest.us.sentry.io/4511089470930944
