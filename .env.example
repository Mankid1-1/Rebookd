# Copy this file to .env and replace the example values.
# This is the authoritative sample for the current app.
# Ignore older env templates that mention unsupported integrations.

ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
DATABASE_PATH=rebookd.db
SECRET_KEY=replace-with-a-long-random-secret

# Optional Stripe configuration used for best-effort customer creation at signup.
STRIPE_SECRET_KEY=

# Optional Twilio configuration used for webhook verification and tenant matching.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
