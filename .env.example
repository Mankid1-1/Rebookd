# ─── Database ─────────────────────────────────────────────────────────────────
# Free MySQL: Railway (railway.app), PlanetScale (planetscale.com), Aiven (aiven.io)
# Railway sets this automatically as RAILWAY_URL; fallback in code uses DATABASE_URL or RAILWAY_URL.
DATABASE_URL=mysql://root:hZuySTkRmnlKMBwjIoirhLVErKiSuazW@autorack.proxy.rlwy.net:32028/railway
RAILWAY_URL=$DATABASE_URL

# ─── Auth ─────────────────────────────────────────────────────────────────────
# 32+ character random string — signs session cookies
# Generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=k9mX2vQpL7nRjW4tYeHcBsDuFzA8NgE1

# ─── OAuth (leave as-is for local email/password auth) ────────────────────────
VITE_APP_ID=rebookd
OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:3000
OWNER_OPEN_ID=placeholder

# ─── Twilio — required for real SMS sending ───────────────────────────────────
# Sign up free at twilio.com → Console → Account Info
# Without these: messages are saved to DB but not delivered via SMS (dev mode)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15550000000

# ─── Inbound SMS (STOP compliance) ───────────────────────────────────────────
# In Twilio Console → Phone Numbers → your number → Messaging → Webhook URL:
# Set to: https://yourdomain.com/api/twilio/inbound
# This enables: two-way SMS, STOP/UNSUBSCRIBE compliance (TCPA required)

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_1...
STRIPE_PRICE_GROWTH=price_1...
STRIPE_PRICE_SCALE=price_1...

# ─── Email (SendGrid, optional but recommended in production)
SENDGRID_API_KEY=SG.xxxxx
EMAIL_FROM_ADDRESS=hello@rebookd.com

