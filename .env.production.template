# ═══════════════════════════════════════════════════════════════════════════════
# 🚀 REBOOKED PRODUCTION ENVIRONMENT TEMPLATE
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in ALL required values before launching!
# ═══════════════════════════════════════════════════════════════════════════════

# ─── DATABASE (REQUIRED) ───────────────────────────────────────────────────────────
# MySQL connection string for production database
DATABASE_URL=mysql://username:password@your-host:3306/rebooked_prod

# ─── AUTHENTICATION (REQUIRED) ─────────────────────────────────────────────────────
# 32+ character random string for JWT token signing
# Generate: https://generate-secret.vercel.app/32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ─── APPLICATION URLS (REQUIRED) ───────────────────────────────────────────────────
# Frontend application URL
FRONTEND_URL=https://app.rebooked.com

# Backend API URL  
BACKEND_URL=https://api.rebooked.com

# ─── STRIPE BILLING (CRITICAL - REQUIRED) ───────────────────────────────────────────
# Get these from your Stripe Dashboard → Developers → API keys
# IMPORTANT: Use LIVE keys for production, not TEST keys!

STRIPE_SECRET_KEY=sk_live_your-live-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_live_your-live-publishable-key-here

# Webhook secret from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Full Plan: $199/mo + 15% revenue share (prod_UCF4dvSJSzp8Hf)
STRIPE_FULL_PRODUCT_ID=prod_UCF4dvSJSzp8Hf
STRIPE_FIXED_PRICE_ID=price_1TDqZtPC6Kl5W2cCTLQrYsKS
STRIPE_METERED_PRICE_ID=price_1TDx2sPC6Kl5W2cCGPQgHuXz
# Flex Plan: $29-$149/mo slider + 20% revenue share (prod_UDONY2mD0w5gHq)
STRIPE_FLEX_PRODUCT_ID=prod_UDONY2mD0w5gHq
STRIPE_FLEX_METERED_PRICE_ID=price_1TFgLpPC6Kl5W2cCdN22c86O

# ─── REFERRAL SYSTEM (REQUIRED) ───────────────────────────────────────────────────────
# Referral program configuration
REFERRAL_REWARD_AMOUNT=50
REFERRAL_MINIMUM_MONTHS=6
REFERRAL_EXPIRY_DAYS=90
REFERRAL_PROGRAM_ENABLED=true

# ─── EMAIL SERVICE (REQUIRED) ────────────────────────────────────────────────────────
# SendGrid API key for transactional emails
# Get from SendGrid Dashboard → Settings → API Keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# From email address for all system emails
EMAIL_FROM_ADDRESS=hello@rebooked.com

# ─── SMS SERVICE (REQUIRED) ───────────────────────────────────────────────────────────
# Telnyx API key for SMS messaging (recommended)
# Get from Telnyx Dashboard → Mission Control → API Keys
TELNYX_API_KEY=KEY0your-telnyx-api-key-here
TELNYX_FROM_NUMBER=+15550000000

# Alternative: Twilio (only if not using Telnyx)
# TWILIO_ACCOUNT_SID=ACyour-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+15550000001

# ─── SECURITY (REQUIRED) ─────────────────────────────────────────────────────────────
# 64 hex character encryption key for PII data
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-hex-encryption-key-here

# Webhook signing secret for API webhooks
WEBHOOK_SECRET=your-webhook-signing-secret

# ─── MONITORING (REQUIRED) ───────────────────────────────────────────────────────────
# Sentry DSN for error tracking and monitoring
# Get from Sentry Dashboard → Settings → Client Keys (DSN)
SENTRY_DSN=https://your-sentry-dsn-here

# ─── OPTIONAL ENHANCEMENTS ───────────────────────────────────────────────────────────
# OpenAI API key for AI-powered features (optional)
OPENAI_API_KEY=sk-your-openai-api-key

# Rate limiting for SMS (optional)
SMS_HOURLY_CAP=1000
SMS_DAILY_CAP_PER_TENANT=10000

# CORS configuration (if needed)
CORS_ORIGIN=https://app.rebooked.com

# Cookie domain for subdomains (optional)
# COOKIE_DOMAIN=.rebooked.com

# ─── DEPLOYMENT (SSH to VPS) ───────────────────────────────────────────────────────
# Set password or key path (not both). SSH key is recommended.
# DEPLOY_SSH_HOST=173.249.56.141
# DEPLOY_SSH_PORT=22
# DEPLOY_SSH_USER=root
# DEPLOY_SSH_PASSWORD=your-ssh-password
# DEPLOY_SSH_KEY_PATH=/path/to/id_rsa

# ─── SOFT LAUNCH / FOUNDING PROGRAM ───────────────────────────────────────────────
# Set to 'false' when founding program ends (default: true)
# SOFT_LAUNCH_ACTIVE=true

# ─── REFERRAL AUTO-PAYOUT ─────────────────────────────────────────────────────────
# Set to 'true' to enable automatic daily referral payout processing
# REFERRAL_AUTO_PAYOUT_ENABLED=false

# ─── DEVELOPMENT ONLY (REMOVE IN PRODUCTION) ────────────────────────────────────────
# WEBHOOK_ALLOW_UNSIGNED=true

# ═══════════════════════════════════════════════════════════════════════════════
