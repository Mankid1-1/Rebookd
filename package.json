{
  "name": "rebooked",
  "version": "2.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "fix-env": "node scripts/fix-env.cjs",
    "setup-sentry": "node scripts/setup-sentry.js",
    "install": "node scripts/install-permissions.js",
    "deploy": "./scripts/deploy.sh",
    "deploy:windows": "scripts/deploy.bat",
    "test": "node scripts/run-all-tests.js",
    "test:quick": "node scripts/run-all-tests.js quick",
    "test:unit": "vitest run",
    "test:client": "vitest run client",
    "test:server": "vitest run server",
    "test:e2e": "vitest run e2e",
    "test:api": "vitest run api",
    "test:db": "vitest run db",
    "test:performance": "vitest run performance",
    "test:load": "vitest run load",
    "test:memory": "vitest run memory",
    "test:security": "vitest run security",
    "npm audit": "npm audit",
    "test:a11y": "vitest run a11y",
    "test:wcag": "vitest run wcag",
    "test:components": "vitest run components",
    "test:ui": "vitest run ui",
    "test:visual": "vitest run visual",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "cross-env E2E_API_URL=http://localhost:3000 npx tsx e2e/smoke.test.ts",
    "build": "cross-env NODE_ENV=production node scripts/build.mjs",
    "build:app": "cd client && npm run build && cd ..",
    "build:server": "npx tsc --project tsconfig.server.json",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node --max-old-space-size=4096 dist/app.js",
    "check": "tsc --noEmit",
    "check:types": "tsc --noEmit --skipLibCheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:security": "eslint . --ext .ts,.tsx --config eslint.config.security.js",
    "db:audit": "node scripts/database-audit.js",
    "db:fix": "mysql -h localhost -u root -p rebooked < scripts/database-audit-fix.sql",
    "dev": "cross-env NODE_ENV=development npx tsx watch server/_core/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\" \"npm run watch:client\"",
    "db:push": "npx drizzle-kit generate && npx drizzle-kit migrate",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:seed:plans": "tsx server/seeds/seedPlans.ts",
    "db:seed:all": "npm run db:seed:plans",
    "db:reset": "npx drizzle-kit drop && npx drizzle-kit migrate",
    "worker": "cross-env NODE_ENV=development npx tsx server/worker.ts",
    "worker:prod": "cross-env NODE_ENV=production node dist/worker.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 delete ecosystem.config.js || exit 0",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs rebookd-server",
    "pm2:monitor": "pm2 monit",
    "docker:build": "docker-compose -f docker-compose.prod.yml build",
    "docker:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "docker:restart": "docker-compose -f docker-compose.prod.yml restart",
    "watch:client": "cd client && npm run dev && cd ..",
    "e2e:smoke": "cross-env E2E_API_URL=http://localhost:3000 npx tsx e2e/smoke.test.ts",
    "validate": "npm run check:types && npm run format:check && npm run test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
